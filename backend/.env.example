APP_NAME=FARAN AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=True
# Optional. Defaults to the local backend/faran.db SQLite file.
# DATABASE_URL=sqlite:///./faran.db
AUTH_ENABLED=False
API_ACCESS_KEY=
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ORIGINS=
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

AI_PROVIDER=openai
AI_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.6-sol
OPENAI_ANALYSIS_MODEL=gpt-5.6-luna
OPENAI_REASONING_EFFORT=low
OPENAI_REASONING_CONTEXT=all_turns
OPENAI_TEXT_VERBOSITY=medium
OPENAI_PROMPT_CACHE_MODE=implicit
OPENAI_CONTEXT_COMPACT_THRESHOLD=200000
# Optional connected-app or remote MCP access. Allow only reviewed read-only tools.
OPENAI_CONNECTOR_ID=
OPENAI_CONNECTOR_AUTHORIZATION=
OPENAI_CONNECTOR_ALLOWED_TOOLS=
OPENAI_MCP_SERVER_URL=
OPENAI_MCP_SERVER_LABEL=faran_workspace
OPENAI_MCP_ALLOWED_TOOLS=
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=2
AGENT_RUNTIME=openai
AGENT_MAX_TURNS=12
AGENT_WORKFLOW_TIMEOUT_SECONDS=180
WORKFLOW_MAX_ATTEMPTS=3
OPENAI_TRACING_ENABLED=True
OPENAI_TRACE_INCLUDE_SENSITIVE_DATA=False

EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
